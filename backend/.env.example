# Copy to .env and adjust. NEVER commit a real .env.
APP_NAME=Mini ERP
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL connection
DATABASE_URL=postgresql+psycopg2://erp:erp@localhost:5432/mini_erp

# JWT — generate a strong secret for production (e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY=CHANGE_ME_IN_PROD_super_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Business defaults
LOW_STOCK_THRESHOLD=5
